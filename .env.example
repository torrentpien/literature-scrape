# Anthropic Claude API key (required for "claude" summarization backend)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Claude model to use for summarization
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Summarization backend: "claude" (API) or "local" (rule-based, no API key needed)
SUMMARIZER_BACKEND=claude

# Email for CrossRef/OpenAlex polite pool (faster rate limits)
CROSSREF_MAILTO=your-email@nccu.edu.tw
OPENALEX_MAILTO=your-email@nccu.edu.tw

# Schedule interval in hours (default: 168 = weekly)
SCHEDULE_INTERVAL_HOURS=168
