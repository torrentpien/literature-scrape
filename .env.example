# ── Summarization ─────────────────────────────────────────────────────────
# Backend: "openai" (default), "claude", or "local"
SUMMARIZER_BACKEND=openai

# OpenAI (required if SUMMARIZER_BACKEND=openai)
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (required if SUMMARIZER_BACKEND=claude)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── API polite-pool emails ────────────────────────────────────────────────
# Optional: your email for CrossRef/OpenAlex (faster rate limits)
CROSSREF_MAILTO=your-email@nccu.edu.tw
OPENALEX_MAILTO=your-email@nccu.edu.tw

# ── Scheduler ─────────────────────────────────────────────────────────────
# Hours between automatic pipeline runs (default 168 = weekly)
SCHEDULE_INTERVAL_HOURS=168
